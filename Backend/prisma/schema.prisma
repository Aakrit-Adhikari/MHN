generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  name            String?
  username        String           @unique
  email           String?          @unique
  passwordHash    String           @map("password_hash")
  role            UserRole         @default(EMPLOYEE)
  status          UserStatus       @default(ACTIVE)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  userPermissions UserPermission[]

  @@map("users")
}

model Permission {
  id              String           @id @default(cuid())
  name            String
  key             String           @unique
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  userPermissions UserPermission[]

  @@map("permissions")
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String     @map("user_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

model TourCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tours     Tour[]

  @@map("tour_categories")
}

model Tour {
  id              String        @id @default(cuid())
  categoryId      String?       @map("category_id")
  slug            String        @unique
  title           String
  summary         String
  description     String
  duration        String?
  altitude        String?
  location        String?
  groupSize       String?       @map("group_size")
  bestSeason      String?       @map("best_season")
  price           Int?
  coverImageUrl   String?       @map("cover_image_url")
  contentImageUrl String?       @map("content_image_url")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  category        TourCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  faqs            TourFaq[]
  gallery         TourGallery[]
  inquiries       Inquiry[]
  bookings        Booking[]

  @@map("tours")
}

model TourFaq {
  id        String   @id @default(cuid())
  tourId    String   @map("tour_id")
  question  String
  answer    String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tour      Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@map("tour_faqs")
}

model TourGallery {
  id        String   @id @default(cuid())
  tourId    String   @map("tour_id")
  imageUrl  String   @map("image_url")
  caption   String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tour      Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@map("tour_gallery")
}

model Inquiry {
  id            String        @id @default(cuid())
  tourId        String?       @map("tour_id")
  inquiryType   InquiryType   @map("inquiry_type")
  name          String
  email         String
  phone         String?
  preferredDate DateTime?     @map("preferred_date")
  message       String
  status        InquiryStatus @default(NEW)
  sourceType    SourceType?   @map("source_type")
  sourceName    String?       @map("source_name")
  sourceMedium  String?       @map("source_medium")
  campaignName  String?       @map("campaign_name")
  utmSource     String?       @map("utm_source")
  utmMedium     String?       @map("utm_medium")
  utmCampaign   String?       @map("utm_campaign")
  utmTerm       String?       @map("utm_term")
  utmContent    String?       @map("utm_content")
  referrerUrl   String?       @map("referrer_url")
  landingPage   String?       @map("landing_page")
  sourceNote    String?       @map("source_note")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  tour          Tour?         @relation(fields: [tourId], references: [id], onDelete: SetNull)
  booking       Booking?

  @@map("inquiries")
}

model Booking {
  id            String        @id @default(cuid())
  inquiryId     String?       @unique @map("inquiry_id")
  tourId        String?       @map("tour_id")
  customerName  String        @map("customer_name")
  customerEmail String?       @map("customer_email")
  customerPhone String?       @map("customer_phone")
  bookingDate   DateTime?     @map("booking_date")
  amount        Int?
  currency      String        @default("USD")
  status        BookingStatus @default(PENDING)
  notes         String?
  sourceType    SourceType?   @map("source_type")
  sourceName    String?       @map("source_name")
  sourceMedium  String?       @map("source_medium")
  campaignName  String?       @map("campaign_name")
  utmSource     String?       @map("utm_source")
  utmMedium     String?       @map("utm_medium")
  utmCampaign   String?       @map("utm_campaign")
  utmTerm       String?       @map("utm_term")
  utmContent    String?       @map("utm_content")
  referrerUrl   String?       @map("referrer_url")
  landingPage   String?       @map("landing_page")
  sourceNote    String?       @map("source_note")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  inquiry       Inquiry?      @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  tour          Tour?         @relation(fields: [tourId], references: [id], onDelete: SetNull)

  @@map("bookings")
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("blogs")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  FINANCE
  HR
  OPERATIONS
  EMPLOYEE
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum InquiryType {
  CONTACT
  CHARTER
  BOOKING
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  CONTACTED
  CONVERTED
  CLOSED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum SourceType {
  WEBSITE
  ADS
  SOCIAL
  OTA
  WHATSAPP
  PHONE
  REFERRAL
  WALK_IN
  MANUAL
  OTHER
}
