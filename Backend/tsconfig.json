{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": false,
    "jsx": "react-jsx",
    "types": ["node"]
  },
  "include": ["src", "dist/api/tours"],
  "exclude": ["node_modules", "dist"]
}
